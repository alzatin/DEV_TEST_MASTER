                    },
                    {
                      "atomType": "Code",
                      "x": 0.32584269662921345,
                      "y": 0.3940298507462686,
                      "uniqueID": "id-4043",
                      "ioValues": [
                        {
                          "name": "base1",
                          "ioValue": 4
                        },
                        {
                          "name": "base2",
                          "ioValue": 2
                        },
                        {
                          "name": "tr_height",
                          "ioValue": 1
                        },
                        {
                          "name": "height",
                          "ioValue": 4
                        },
                        {
                          "name": "fillet",
                          "ioValue": 0
                        }
                      ],
                      "interpreterVersion": 0,
                      "code": "\n// Example Code\nconst Inputs = [\n  { inputName: \"base1\", type: \"number\", defaultValue: 40 },\n  { inputName: \"base2\", type: \"number\", defaultValue: 25 },\n  { inputName: \"tr_height\", type: \"number\", defaultValue: 25 },\n  { inputName: \"height\", type: \"number\", defaultValue: 10 },\n  { inputName: \"fillet\", type: \"number\", defaultValue: 0 }\n  \n];\n\n\n\nconst dx = (base1 - base2) / 2;\n\nconst trapezoid = replicad.draw().lineTo([base1, 0])                 // bottom right\n  .lineTo([base1 - dx, tr_height])       // top right\n  .lineTo([dx, tr_height])               // top left\n  .close()   \nlet newPlane = replicad.makePlane()\n\nlet sketchCir = trapezoid.sketchOnPlane(newPlane)\nlet cyl = sketchCir.extrude(height)\nlet cylObj = {\n  geometry: [cyl],\n  dimension: \"3D\",\n  tags: [\"createdCylinder\"],\n  color: \"#A3CE5B\",\n  plane: null,\n  bom: []\n};\nreturn cylObj"
                    },
                    {
                      "atomType": "Code",
                      "x": 0.6198501872659177,
                      "y": 0.4567164179104477,
                      "uniqueID": "id-4044",
                      "ioValues": [
                        {
                          "name": "shape",
                          "ioValue": "__GEOMETRY_INPUT__"
                        },
                        {
                          "name": "fillet",
                          "ioValue": 0
                        }
                      ],
                      "interpreterVersion": 0,
                      "code": "\n// Example Code\nconst Inputs = [\n  { inputName: \"shape\", type: \"geometry\", defaultValue: null },\n  { inputName: \"fillet\", type: \"number\", defaultValue: 1 },\n];\n\nlet importedShape = library[shape]\nlet newPlane = replicad.makePlane()\n\nif (fillet > 0){\n  \nlet filletedCyl = importedShape.geometry[0].fillet(fillet, (e) => e.inDirection([0, 0, 1]));\n return {\n  geometry: [filletedCyl],\n  dimension: \"3D\",\n  tags: [\"createdShape\"],\n  color: '#A3CE5B',\n  plane: newPlane,\n  bom: [],\n}\n}\nelse{\n  return {\n  geometry: [importedShape],\n  dimension: \"3D\",\n  tags: [\"createdShape\"],\n  color: '#A3CE5B',\n  plane: newPlane,\n  bom: [],\n}\n  \n}\n"
                    },
